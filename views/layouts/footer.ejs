<footer class="bg-dark text-white pt-5 pb-3 mt-5">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-4">
                <h5 class="fw-bold text-danger mb-3">Rattan Electricals</h5>
                <p>Authorized Havells Distributor in Rewari providing genuine electrical products, wholesale rates, and premium service.</p>
                <div class="d-flex mt-3">
                    <a href="#" class="text-white me-3 fs-5"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-white me-3 fs-5"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <h5 class="fw-bold mb-3">Quick Links</h5>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="/" class="text-white text-decoration-none">Home</a></li>
                    <li class="mb-2"><a href="/about" class="text-white text-decoration-none">About Us</a></li>
                    <li class="mb-2"><a href="/categories" class="text-white text-decoration-none">Categories</a></li>
                    <li class="mb-2"><a href="/products" class="text-white text-decoration-none">Products</a></li>
                    <li class="mb-2"><a href="/contact" class="text-white text-decoration-none">Contact Us</a></li>
                </ul>
            </div>
            <div class="col-md-4 mb-4">
                <h5 class="fw-bold mb-3">Contact Info</h5>
                <p><i class="bi bi-geo-alt-fill text-danger me-2"></i> <%= businessInfo.address %></p>
                <p><i class="bi bi-telephone-fill text-danger me-2"></i> <a href="tel:<%= businessInfo.phone %>" class="text-white text-decoration-none"><%= businessInfo.phone %></a></p>
                <p><i class="bi bi-envelope-fill text-danger me-2"></i> contact@example.com</p>
            </div>
        </div>
        <hr class="mt-4 mb-3 border-secondary">
        <div class="text-center text-secondary">
            <small>&copy; <%= new Date().getFullYear() %> <%= businessInfo.name %>. All Rights Reserved.</small>
        </div>
    </div>
</footer>

<!-- Sticky Mobile Call Button -->
<div class="d-block d-md-none fixed-bottom bg-white border-top p-2 text-center shadow">
    <div class="row g-2">
        <div class="col-6">
            <a href="tel:<%= businessInfo.phone %>" class="btn btn-primary w-100 fw-bold">
                <i class="bi bi-telephone-fill me-2"></i> Call Now
            </a>
        </div>
        <div class="col-6">
             <a href="https://wa.me/91<%= businessInfo.phone.replace(/^0/, '') %>" class="btn btn-success w-100 fw-bold" target="_blank">
                <i class="bi bi-whatsapp me-2"></i> WhatsApp
            </a>
        </div>
    </div>
</div>

<!-- Sticky WhatsApp Desktop -->
<a href="https://wa.me/91<%= businessInfo.phone.replace(/^0/, '') %>" class="d-none d-md-flex align-items-center justify-content-center bg-success text-white rounded-circle shadow position-fixed" style="width: 60px; height: 60px; bottom: 30px; right: 30px; z-index: 1000; text-decoration: none;" target="_blank">
    <i class="bi bi-whatsapp fs-2"></i>
</a>

<!-- Bootstrap 5 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
