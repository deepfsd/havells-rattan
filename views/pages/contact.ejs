<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<% if (!isPageActive) { %>
    <header class="bg-light text-dark py-5" style="min-height: 60vh; display: flex; align-items: center;">
        <div class="container text-center">
            <i class="bi bi-tools text-danger mb-3" style="font-size: 5rem;"></i>
            <h1 class="display-5 fw-bold">Under Maintenance</h1>
            <p class="lead text-muted">We are currently performing maintenance on our contact system.</p>
            <div class="my-4">
                <p class="mb-2"><strong>You can still reach us directly at:</strong></p>
                <a href="tel:<%= businessInfo.phone %>" class="btn btn-outline-primary btn-lg fw-bold"><i class="bi bi-telephone-fill me-2"></i> <%= businessInfo.phone %></a>
            </div>
            <a href="/" class="btn btn-outline-danger mt-3">Return to Home</a>
        </div>
    </header>
<% } else { %>
    <header class="bg-danger text-white py-5">
        <div class="container text-center">
            <h1 class="display-5 fw-bold">Contact Us</h1>
            <p class="lead">Get in touch for wholesale rates, bulk orders, or product inquiries.</p>
        </div>
    </header>

    <section class="py-5 bg-light">
        <div class="container py-4">
            <div class="row g-5">
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h4 class="fw-bold mb-4">Store Information</h4>
                            <div class="d-flex mb-3">
                                <div class="text-danger me-3 fs-3"><i class="bi bi-geo-alt-fill"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-1">Address</h6>
                                    <p class="text-muted mb-0"><%= businessInfo.address %></p>
                                </div>
                            </div>
                            <div class="d-flex mb-3">
                                <div class="text-danger me-3 fs-3"><i class="bi bi-telephone-fill"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-1">Phone</h6>
                                    <p class="text-muted mb-0"><a href="tel:<%= businessInfo.phone %>" class="text-decoration-none"><%= businessInfo.phone %></a></p>
                                </div>
                            </div>
                            <div class="d-flex mb-3">
                                <div class="text-danger me-3 fs-3"><i class="bi bi-clock-fill"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-1">Business Hours</h6>
                                    <p class="text-muted mb-0">Monday - Saturday: 9:00 AM - 8:00 PM<br>Sunday: Closed</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm overflow-hidden">
                        <div class="bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center text-muted" style="height: 300px;">
                            <div class="text-center">
                                <i class="bi bi-map fs-1"></i>
                                <p class="mt-2">Google Maps Embed Placeholder</p>
                                </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4 p-md-5">
                            <h3 class="fw-bold mb-3">Send us a Message</h3>
                            <p class="text-muted mb-4">Fill out the form below to request a quote or ask a question. We will get back to you shortly.</p>
                            
                            <form action="#" method="POST">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="name" class="form-label fw-bold">Your Name *</label>
                                        <input type="text" class="form-control form-control-lg bg-light" id="name" name="name" required placeholder="John Doe">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="phone" class="form-label fw-bold">Phone Number *</label>
                                        <input type="tel" class="form-control form-control-lg bg-light" id="phone" name="phone" required placeholder="Enter mobile number">
                                    </div>
                                    <div class="col-12">
                                        <label for="email" class="form-label fw-bold">Email Address (Optional)</label>
                                        <input type="email" class="form-control form-control-lg bg-light" id="email" name="email" placeholder="john@example.com">
                                    </div>
                                    <div class="col-12">
                                        <label for="message" class="form-label fw-bold">Message / Requirements *</label>
                                        <textarea class="form-control form-control-lg bg-light" id="message" name="message" rows="5" required placeholder="Please list the products you need a quote for..."></textarea>
                                    </div>
                                    <div class="col-12 mt-4">
                                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold py-3"><i class="bi bi-send-fill me-2"></i> Send Message / Request Quote</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
<% } %>

<%- include('../layouts/footer') %>